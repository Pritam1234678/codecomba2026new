# ─────────────────────────────────────────────────────────────────────────────
# CodeCombat — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# This file IS committed to git (no real secrets here).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=codecombat
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32 | base64
JWT_SECRET=your_base64_encoded_secret_here
JWT_EXPIRATION=86400000

# ─── Valkey / Redis ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password_here

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://your-domain.com
SERVER_PORT=8080

# ─── CORS allowed origins (comma-separated, REQUIRED in production) ──────────
# No wildcards. List every exact origin that your frontend may use.
APP_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ─── Judge Workers ────────────────────────────────────────────────────────────
# 8 = good for 2-4 CPU server, handles ~100 concurrent users
JUDGE_WORKERS=8
COMPILER_WORKERS=6
COMPILER_QUEUE_SIZE=100
PRACTICE_WORKERS=4
PRACTICE_QUEUE_SIZE=50
COMPILER_WS_MAX_SESSIONS=20
COMPILER_WS_MAX_RUNTIME_SEC=120
COMPILER_WS_RATE_WINDOW_SEC=60
COMPILER_WS_RATE_LIMIT_ANON=5

# ─── Sandbox (REQUIRED in production) ────────────────────────────────────────
# bwrap (bubblewrap) and prlimit are used to isolate user code:
#   apt-get install bubblewrap util-linux
# Setting SANDBOX_ENABLED=false bypasses isolation. NEVER do that in prod.
SANDBOX_ENABLED=true
SANDBOX_BWRAP_PATH=/usr/bin/bwrap
SANDBOX_PRLIMIT_PATH=/usr/bin/prlimit

# ─── Cloudflare Turnstile (server-side verification) ────────────────────────
# Secret key from the Cloudflare Turnstile dashboard. Never commit the real value.
TURNSTILE_SECRET=0x_REPLACE_WITH_YOUR_SECRET
TURNSTILE_ENABLED=true

# ─── Live Duel Mode ───────────────────────────────────────────────────────────
# Tuning for live 1v1 duels. Defaults are baked into @Value annotations,
# so omitting these still produces documented behavior.
DUEL_COOLDOWN_SEC=5
DUEL_QUEUE_TIMEOUT_SEC=120
DUEL_GRACE_PERIOD_SEC=120
DUEL_DRAW_TIMEOUT_SEC=600
