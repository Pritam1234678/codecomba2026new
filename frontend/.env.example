# Frontend Environment Variables Template
# Copy to .env for local dev, or set in Vercel/Netlify dashboard for production

# Backend API URL
# Local dev: leave empty (Vite proxy handles it)
# Production: set to your backend URL
VITE_API_URL=https://your-backend-domain.com/api

# Cloudflare Turnstile site key (public, safe in the browser bundle).
# Get this from the Cloudflare Turnstile dashboard for your domain.
VITE_TURNSTILE_SITE_KEY=0x_REPLACE_WITH_YOUR_SITE_KEY
